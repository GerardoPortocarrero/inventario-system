rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function getRole() {
      return getUserData().rolId;
    }

    function getSedeId() {
      return getUserData().sedeId;
    }

    function isAdmin() {
      return isAuthenticated() && getRole() == 'admin';
    }

    function isSupervisor() {
      return isAuthenticated() && getRole() == 'supervisor';
    }

    function isPreventista() {
      return isAuthenticated() && getRole() == 'preventista';
    }

    function isAlmacenero() {
      return isAuthenticated() && getRole() == 'almacenero';
    }

    // --- Collection Rules ---

    match /roles/{roleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /sedes/{sedeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /tiposBebida/{tipoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /productos/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /usuarios/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin() || isSupervisor());
      allow write: if isAdmin();
      allow update: if request.auth.uid == userId && 
                    request.resource.data.rolId == resource.data.rolId &&
                    request.resource.data.sedeId == resource.data.sedeId;
    }

    match /inventario/{inventoryId} {
      allow read: if isAdmin() || isSupervisor() || (isAuthenticated() && resource.data.sedeId == getSedeId());
      allow write: if isAdmin() || (isAlmacenero() && request.resource.data.sedeId == getSedeId());
    }

    match /unidadesDeStock/{unitId} {
      allow read: if isAdmin() || isSupervisor() || (isAuthenticated() && resource.data.sedeId == getSedeId());
      allow write: if isAdmin() || (isAlmacenero() && request.resource.data.sedeId == getSedeId());
    }

    match /inventario_diario/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAlmacenero() && request.resource.data.sedeId == getSedeId());
      allow update: if isAdmin() || 
                    (isAlmacenero() && request.resource.data.sedeId == getSedeId()) ||
                    (isPreventista() && request.resource.data.sedeId == getSedeId());
    }

    match /transito/{docId} {
      allow read: if isAdmin() || isSupervisor() || isAlmacenero();
      allow write: if isAdmin() || (isAlmacenero() && request.resource.data.sedeId == getSedeId());
    }

    match /ordenes/{orderId} {
      allow read: if isAdmin() || isSupervisor() || 
                  (isPreventista() && resource.data.preventistaId == request.auth.uid);

      // CORRECCIÓN: Permitir create si es Admin O si es Preventista con los datos correctos
      allow create: if isAdmin() || 
                    (isPreventista() && request.resource.data.sedeId == getSedeId() && 
                     request.resource.data.preventistaId == request.auth.uid);
      
      allow update: if isAdmin() || 
                    (isPreventista() && resource.data.preventistaId == request.auth.uid &&
                     resource.data.estadoOrden == 'PENDIENTE');

      allow delete: if isAdmin();
    }
  }
}
